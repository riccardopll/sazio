{
  "name": "@sazio/server",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "oxfmt && oxlint --fix && tsc --noEmit -p tsconfig.json",
    "db:migrate": "drizzle-kit generate && wrangler d1 migrations apply sazio-db --remote",
    "db:migrate:local": "drizzle-kit generate && wrangler d1 migrations apply sazio-db",
    "db:studio": "drizzle-kit studio",
    "db:studio:local": "drizzle-kit studio --config drizzle.config.local.ts",
    "dev": "wrangler dev",
    "test": "vitest --run"
  },
  "dependencies": {
    "@clerk/backend": "^2.29.2",
    "@sazio/shared": "workspace:*",
    "@trpc/server": "^11.12.0",
    "dotenv": "^17.2.3",
    "hono": "^4.11.7"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.1",
    "@cloudflare/workers-types": "^4.20260109.0",
    "drizzle-kit": "^0.31.8",
    "vitest": "^3.2.4"
  }
}
